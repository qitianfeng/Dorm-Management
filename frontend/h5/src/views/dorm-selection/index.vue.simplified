  cursor: pointer;
  padding: 14px 16px;

  &.selected {
    border-color: #1989fa;
    background: #f8f9ff;
    transform: translateY(-4px);
  }

  &.disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }
}

.room-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.room-number {
  font-size: 18px;
