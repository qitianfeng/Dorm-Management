  color: #323233;
}

.room-body {
  display: flex;
  gap: 12px;
}

.room-type {
  font-size: 13px;
  color: #323233;
}

.room-facilities {
  font-size: 12px;
  color: #969799;
}

.bed-selection {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
