  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: linear-gradient(135deg, #52c41a 0%, #764ba2 100%);
  box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
  backdrop-filter: blur(10px);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: success-pulse 2s ease-in-out infinite;
}

