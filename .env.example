# Docker Compose 环境变量配置示例
# 复制此文件为 .env 并修改配置

# MySQL配置
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=dormitory_db

# 后端配置
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/dormitory_db?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&connectionCollation=utf8mb4_unicode_ci
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=123456

# Redis配置（可选）
# SPRING_DATA_REDIS_HOST=redis
# SPRING_DATA_REDIS_PORT=6379

# 端口配置
BACKEND_PORT=8080
ADMIN_PORT=3000
H5_PORT=3001
MYSQL_PORT=3306
REDIS_PORT=6379
